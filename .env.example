# Auto Code OS — Environment Configuration

# ── Server ───────────────────────────────────────────────
SERVER_PORT=8080
WEB_PORT=3000
JWT_SECRET=change-this-dev-secret
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
QUEUE_WORKER_ENABLED=true
QUEUE_WORKER_INTERVAL_MS=2000
QUEUE_WORKER_CONCURRENCY=1
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgres://autocodeuser:autocodepass@localhost:5434/autocodeosdb?sslmode=disable
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_SECONDS=1800
DB_CONN_MAX_IDLE_TIME_SECONDS=300

# Phase 3 sandbox runtime. Use "stub" for local plumbing tests or "docker" for isolated execution.
SANDBOX_RUNTIME=stub
SANDBOX_IMAGE=auto-code-os-sandbox:latest
SANDBOX_WORKSPACE_ROOT=/tmp/auto-code-os/workspaces
SANDBOX_WORKSPACE_RETENTION_HOURS=72
SANDBOX_WORKSPACE_CLEANUP_INTERVAL_MINUTES=60
SANDBOX_MEMORY_MB=1024
SANDBOX_NANO_CPUS=1000000000

# ── Logging ──────────────────────────────────────────────
LOG_LOCAL_RETENTION_DAYS=14
LOG_FILE_ROOT=/tmp/auto-code-os/logs


# ── LLM Provider ──────────────────────────────────────────
# Supported: openai, anthropic, gemini, gateway
LLM_PROVIDER=openai

# Provider-specific API keys (set the one matching your provider)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GEMINI_API_KEY=your-gemini-key-here

# Optional: Override the default model
# LLM_MODEL=gpt-4o

# Phase 4 gateway routing defaults, used when LLM_PROVIDER=gateway.
LLM_FAST_MODEL=gpt-4o-mini
LLM_BALANCED_MODEL=gpt-4o
LLM_POWERFUL_MODEL=gpt-4o
LLM_ANTHROPIC_BALANCED_MODEL=claude-sonnet-4-20250514
LLM_ANTHROPIC_POWERFUL_MODEL=claude-opus-4-20250514
LLM_GEMINI_FAST_MODEL=gemini-2.5-flash
LLM_GEMINI_BALANCED_MODEL=gemini-2.5-pro
LLM_CIRCUIT_MAX_TOKENS=120000
LLM_CIRCUIT_MAX_COST_USD=2.50
LLM_DEFAULT_OUTPUT_TOKENS=2048
LLM_MAX_RETRIES=2
LLM_EMBEDDING_MODEL=text-embedding-3-small

# ── GitHub ───────────────────────────────────────────────
GITHUB_TOKEN=github_pat_your-token-here
WEBHOOK_SECRET=change-this-webhook-secret

# ── Web UI ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
